# ─────────────────────────────────────────────────────────
# DataVault — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────

# NextAuth — required
NEXTAUTH_SECRET=replace_with_32_random_chars   # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — demo login works without this)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional — demo login works without this)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
